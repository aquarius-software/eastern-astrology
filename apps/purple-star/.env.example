# purple-star 環境変数のサンプル
# このファイルをコピーして .env.local を作成し、各値を設定してください。
#   cp .env.example .env.local
#
# NEXT_PUBLIC_ 接頭辞付きの変数はブラウザに公開されます（秘密情報を入れないこと）。
# NODE_ENV / VERCEL_ENV / VERCEL_URL などのランタイム変数は
# Next.js / Vercel が自動で注入するため、ここには記載しません。
# dev サーバーはポート 3002 で起動します（next dev -p 3002）。

# --- Sanity (CMS) ---
# Next.js 側（localhost:3002）で参照
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2023-03-25"
# Sanity Studio 側（localhost:3333 / *.sanity.studio）で参照。projectId のフォールバック
SANITY_STUDIO_PROJECT_ID=""
# プレビュー／Webhook リバリデーション用シークレット
SANITY_REVALIDATE_SECRET=""
# Sanity Studio のプレビューリンク先サイトURL
SANITY_STUDIO_SITE_URL="http://localhost:3002"

# --- 外部 API キー ---
# Google Maps Places（住所オートコンプリート / クライアント公開）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# Google Time Zone API（サーバー）
GOOGLE_TIMEZONE_API_KEY=""

# --- アプリ / Route Handler ---
# 自アプリの Route Handler のベースURL（/api/* の呼び出し先）
NEXT_PUBLIC_ROUTE_HANDLER_URL="http://localhost:3002"

# --- Upstash Redis（レート制限 / Redis.fromEnv() がこの2変数を自動参照）---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- ISR / キャッシュ（秒）---
# ページの再生成間隔
REVALIDATE_SECONDS="0"
# 命盤（board）APIレスポンスの再生成間隔
BOARD_API_REVALIDATE_SECONDS="3600"

# --- 命盤（board）UI の設定 ---
# 住所オートコンプリートのデバウンス時間（ミリ秒）
NEXT_PUBLIC_DEBOUNCE_MILLISECONDS="2000"
# 緯度経度の小数桁数
NEXT_PUBLIC_LOCATION_DIGITS="3"
# 使用回数の上限
NEXT_PUBLIC_MAX_USED_COUNT="3"
