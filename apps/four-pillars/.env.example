# four-pillars 環境変数のサンプル
# このファイルをコピーして .env.local を作成し、各値を設定してください。
#   cp .env.example .env.local
#
# NEXT_PUBLIC_ 接頭辞付きの変数はブラウザに公開されます（秘密情報を入れないこと）。
# NODE_ENV / VERCEL_ENV / VERCEL_URL などのランタイム変数は
# Next.js / Vercel が自動で注入するため、ここには記載しません。

# --- Sanity (CMS) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2023-03-25"
# プレビュー／Webhook リバリデーション用シークレット
SANITY_REVALIDATE_SECRET=""
# Sanity Studio のプレビューリンク先サイトURL
SANITY_STUDIO_SITE_URL="http://localhost:3001

# --- 外部 API キー ---
# Google Maps Places（住所オートコンプリート / クライアント公開）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# Google Time Zone API（サーバー）
GOOGLE_TIMEZONE_API_KEY=""
# Mapbox Geocoding API（サーバー）
MAPBOX_GEOCODING_API_KEY=""
# --- 画像生成サービス ---
# 非公開画像生成サービスのベースURL（サーバー専用）
IMAGE_SERVICE_URL=""
# 画像生成サービスとの共有認証トークン（サーバー専用）
SERVICE_SHARED_SECRET=""

# --- 四柱推命チャート API ---
# 自アプリの Route Handler のベースURL（/api/* の呼び出し先）
NEXT_PUBLIC_ROUTE_HANDLER_URL="http://localhost:3001"

# --- Upstash Redis（レート制限 / Redis.fromEnv() がこの2変数を自動参照）---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- ISR / キャッシュ（秒）---
# ページの再生成間隔
REVALIDATE_SECONDS="0"
# チャートAPIレスポンスの再生成間隔
CHART_API_REVALIDATE_SECONDS="3600"

# --- チャート表示の設定 ---
NEXT_PUBLIC_CHART_IMAGE_WIDTH="776"
NEXT_PUBLIC_CHART_IMAGE_HEIGHT="480"
# 住所オートコンプリートのデバウンス時間（ミリ秒）
NEXT_PUBLIC_DEBOUNCE_MILLISECONDS="2000"
# 緯度経度の小数桁数
NEXT_PUBLIC_LOCATION_DIGITS="2"
# 使用回数の上限
NEXT_PUBLIC_MAX_USED_COUNT="3"
