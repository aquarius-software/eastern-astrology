{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug four-pillars server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/apps/four-pillars"
    },
    {
      "name": "Next.js: debug four-pillars client-side (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3001",
      "webRoot": "${workspaceFolder}/apps/four-pillars"
    },
    {
      "name": "Next.js: debug four-pillars client-side (Firefox)",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:3001",
      "reAttach": true,
      "pathMappings": [
        { "url": "webpack://_N_E", "path": "${workspaceFolder}" }
      ]
    },
    {
      "name": "Next.js: debug four-pillars full stack",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "runtimeArgs": ["--inspect"],
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}/apps/four-pillars",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/apps/four-pillars"
      }
    }
  ]
}
